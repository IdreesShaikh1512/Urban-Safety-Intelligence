# Copy this file to .env and fill in your values
# On Render, set these as Environment Variables in the dashboard

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/crimedb?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/crimedb?retryWrites=true&w=majority

# Port (Render sets this automatically — do NOT change)
PORT=5000
